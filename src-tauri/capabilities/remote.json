{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-frontend",
  "description": "Allow the deployed web app to control the window for mini mode",
  "windows": ["main"],
  "remote": {
    "urls": ["https://pomodoro.kirwitheli.date/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-decorations",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging"
  ]
}
